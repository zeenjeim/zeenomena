---
import { toEmbedUrl } from '../utils/youtube';

type Props = {
  url?: string;
};
const { url } = Astro.props;
const embedUrl = url ? toEmbedUrl(url) : undefined;
---
{embedUrl && (
  <div class="video-wrapper">
    <iframe
      src={embedUrl}
      title="Project video"
      frameborder="0"
      allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
      allowfullscreen
      loading="lazy"
    ></iframe>
  </div>
)}

<style>
  .video-wrapper {
    position: relative;
    padding-top: 56.25%;
    border-radius: 12px;
    overflow: hidden;
    margin-bottom: 32px;
  }
  .video-wrapper iframe {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    border: none;
  }
</style>
