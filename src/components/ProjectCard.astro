---
import TagChip from './TagChip.astro';
import type { CollectionEntry } from 'astro:content';

type Props = {
  project: CollectionEntry<'projects'>;
};
const { project } = Astro.props;

const tierLabel: Record<string, string> = {
  free: 'Free',
  paid: 'Paid',
  'semi-paid': 'Semi-Paid',
};

const glowMap: Record<string, string> = {
  free: 'rgba(34,197,94,0.3)',
  'semi-paid': 'rgba(59,130,246,0.3)',
  paid: 'rgba(168,85,247,0.4)',
};

const borderMap: Record<string, string> = {
  free: 'rgba(34,197,94,0.6)',
  'semi-paid': 'rgba(59,130,246,0.6)',
  paid: 'rgba(168,85,247,0.6)',
};

const tier = project.data.priceTier;
const glowColor = glowMap[tier] ?? 'rgba(255,255,255,0.1)';
const borderColor = borderMap[tier] ?? 'rgba(255,255,255,0.2)';
---
<a
  href={`/projects/${project.id}`}
  class="project-card"
  style={`--glow: ${glowColor}; --border: ${borderColor};`}
  data-tags={project.data.tags.join(',')}
>
  <div class="thumbnail-wrapper">
    {project.data.thumbnail ? (
      <img
        src={project.data.thumbnail}
        alt={project.data.title}
        class="thumbnail-img"
        loading="lazy"
      />
    ) : (
      <div class="thumbnail-placeholder"></div>
    )}
    <span class="tier-chip">
      <TagChip label={tierLabel[tier] ?? tier} variant={tier} />
    </span>
  </div>
  <h3 class="card-title">{project.data.title}</h3>
  <p class="card-desc">{project.data.description}</p>
  <div class="tag-row">
    {project.data.tags.map((tag) => (
      <TagChip label={tag} variant="tool" />
    ))}
  </div>
</a>

<style>
  .project-card {
    background: #111827;
    border: 2px solid var(--border);
    border-radius: 16px;
    padding: 16px;
    box-shadow: 0 4px 16px rgba(0,0,0,0.4);
    transition: transform 150ms ease, box-shadow 150ms ease, border-color 150ms ease;
    display: block;
    text-decoration: none;
    color: inherit;
  }
  .project-card:hover {
    transform: rotate(-1.5deg) scale(1.03);
    box-shadow: 0 8px 32px var(--glow);
    border-color: color-mix(in srgb, var(--border) 167%, transparent);
  }
  .project-card:focus-visible {
    outline: 2px solid #22d3ee;
    outline-offset: 2px;
  }
  .project-card:active {
    transform: scale(0.97);
    transition-duration: 100ms;
  }
  .thumbnail-wrapper {
    position: relative;
  }
  .thumbnail-img {
    aspect-ratio: 16 / 9;
    object-fit: cover;
    border-radius: 12px;
    width: 100%;
    display: block;
  }
  .thumbnail-placeholder {
    aspect-ratio: 16 / 9;
    border-radius: 12px;
    width: 100%;
    background: linear-gradient(135deg, #1e3a5f, #3b1f6e);
  }
  .tier-chip {
    position: absolute;
    top: 8px;
    right: 8px;
  }
  .card-title {
    font-size: 14px;
    font-weight: 600;
    color: #f1f5f9;
    margin-top: 12px;
    margin-bottom: 0;
  }
  .card-desc {
    font-size: 16px;
    font-weight: 400;
    color: #94a3b8;
    margin-top: 8px;
    margin-bottom: 0;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .tag-row {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 12px;
  }
</style>
