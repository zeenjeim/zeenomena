<section class="hero">
  <h1
    class="hero-headline"
    style="background-image: linear-gradient(135deg, #22d3ee, #a855f7); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;"
  >
    Non-tech business guy building automated systems with AI.
  </h1>
  <p class="hero-sub">
    I build tools that solve sales and trading problems. Browse them, learn from them, or buy them.
  </p>
  <a href="#projects" class="hero-cta">Browse Projects</a>
</section>

<style>
  .hero {
    padding: 64px 24px 48px;
    max-width: 720px;
    margin: 0 auto;
    text-align: center;
  }
  .hero-headline {
    font-size: 48px;
    font-weight: 600;
    line-height: 1.1;
    margin: 0;
  }
  .hero-sub {
    font-size: 16px;
    line-height: 1.5;
    color: #94a3b8;
    margin-top: 16px;
    max-width: 560px;
    margin-left: auto;
    margin-right: auto;
  }
  .hero-cta {
    display: inline-block;
    margin-top: 32px;
    padding: 12px 24px;
    border: 2px solid #22d3ee;
    border-radius: 8px;
    color: #22d3ee;
    font-size: 14px;
    font-weight: 600;
    text-decoration: none;
    transition: background 150ms ease;
  }
  .hero-cta:hover {
    background: rgba(34,211,238,0.1);
  }
  .hero-cta:focus-visible {
    outline: 2px solid #22d3ee;
    outline-offset: 2px;
  }
  .hero-cta:active {
    transform: scale(0.97);
  }
</style>
