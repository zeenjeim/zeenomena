---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroSection from '../components/HeroSection.astro';
import FilterBar from '../components/FilterBar.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { getCollection } from 'astro:content';

const allProjects = await getCollection('projects', ({ data }) =>
  data.status === 'live'
);
const projects = allProjects.sort((a, b) => {
  const dateA = a.data.publishedAt?.getTime() ?? 0;
  const dateB = b.data.publishedAt?.getTime() ?? 0;
  return dateB - dateA;
});
const allTags = [...new Set(projects.flatMap((p) => p.data.tags))].sort();
---

<BaseLayout title="Zeenomena — AI-Built Projects by Zee" description="Non-tech business guy building automated systems with AI. Browse projects, learn from them, or buy them.">
  <main>
    <HeroSection />

    <section id="projects" class="projects-section">
      <FilterBar tags={allTags} />

      <div class="projects-grid">
        {projects.map((project) => (
          <div data-tags={project.data.tags.join(',')}>
            <ProjectCard project={project} />
          </div>
        ))}
      </div>

      <div id="empty-state" class="empty-state" style="display: none;">
        <p class="empty-heading">Nothing here yet.</p>
        <p class="empty-body">Try a different tag, or browse all projects.</p>
      </div>
    </section>

    <footer class="site-footer">
      <div class="footer-content">
        <p class="footer-text">Built by Zee with AI tools. Building in public.</p>
      </div>
    </footer>
  </main>
</BaseLayout>

<style>
.projects-section {
  max-width: 1200px;
  margin: 0 auto;
  padding: 0 24px 64px;
}

.projects-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 16px;
}

@media (min-width: 768px) {
  .projects-grid {
    grid-template-columns: repeat(2, 1fr);
    gap: 16px;
  }
}

@media (min-width: 1024px) {
  .projects-grid {
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }
}

.empty-state {
  text-align: center;
  padding: 48px 24px;
}

.empty-heading {
  font-size: 28px;
  font-weight: 600;
  color: #f1f5f9;
  margin: 0;
}

.empty-body {
  font-size: 16px;
  color: #94a3b8;
  margin-top: 8px;
}

.site-footer {
  border-top: 1px solid rgba(255,255,255,0.1);
  padding: 32px 24px;
  margin-top: 64px;
}

.footer-content {
  max-width: 1200px;
  margin: 0 auto;
  text-align: center;
}

.footer-text {
  font-size: 14px;
  color: #94a3b8;
  margin: 0;
}

</style>
